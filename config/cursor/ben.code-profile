ffHistoryEnabled\\\":false,\\\"contextGraphEnabled\\\":false,\\\"shouldAutoParseCmdKLinks\\\":false,\\\"isFileSyncEnabled\\\":false,\\\"isAiReviewInputExpanded\\\":true,\\\"aiCursorHelpEnabled\\\":true,\\\"aiDocAgentEnabled\\\":false,\\\"removeAIReview\\\":true,\\\"cppShown\\\":4718,\\\"longContextFlagEnabled\\\":true,\\\"explicitelyEnabledAIReview\\\":true,\\\"aiFeaturesCopyPasteState\\\":{\\\"mentions\\\":[{\\\"displayName\\\":\\\"@tmp_loader\\\",\\\"selection\\\":{\\\"type\\\":5,\\\"selectionWithoutUuid\\\":{\\\"relativePath\\\":\\\"/atlas-agents/atlas_agents/workflows/tmp_loader\\\"}},\\\"lastUsedAtUnixMs\\\":1748413297768},{\\\"displayName\\\":\\\"@loader.py\\\",\\\"selection\\\":{\\\"type\\\":2,\\\"selectionWithoutUuid\\\":{\\\"uri\\\":{\\\"$mid\\\":1,\\\"fsPath\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/tmp_loader/loader.py\\\",\\\"external\\\":\\\"file:///Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/tmp_loader/loader.py\\\",\\\"path\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/tmp_loader/loader.py\\\",\\\"scheme\\\":\\\"file\\\"}}},\\\"lastUsedAtUnixMs\\\":1748413297768},{\\\"displayName\\\":\\\"@test_harness.py\\\",\\\"selection\\\":{\\\"type\\\":2,\\\"selectionWithoutUuid\\\":{\\\"uri\\\":{\\\"$mid\\\":1,\\\"fsPath\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/test_harness.py\\\",\\\"external\\\":\\\"file:///Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/test_harness.py\\\",\\\"path\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/test_harness.py\\\",\\\"scheme\\\":\\\"file\\\"}}},\\\"lastUsedAtUnixMs\\\":1748470261054},{\\\"displayName\\\":\\\"@entrypoint.py\\\",\\\"selection\\\":{\\\"type\\\":2,\\\"selectionWithoutUuid\\\":{\\\"uri\\\":{\\\"$mid\\\":1,\\\"fsPath\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/entrypoint.py\\\",\\\"external\\\":\\\"file:///Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/entrypoint.py\\\",\\\"path\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/entrypoint.py\\\",\\\"scheme\\\":\\\"file\\\"}}},\\\"lastUsedAtUnixMs\\\":1748471218053},{\\\"displayName\\\":\\\"@cli.py\\\",\\\"selection\\\":{\\\"type\\\":2,\\\"selectionWithoutUuid\\\":{\\\"uri\\\":{\\\"$mid\\\":1,\\\"fsPath\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/cli.py\\\",\\\"external\\\":\\\"file:///Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/cli.py\\\",\\\"path\\\":\\\"/Users/ben/Documents/code/atlas-core/atlas-agents/atlas_agents/workflows/ee_copilot/cli.py\\\",\\\"scheme\\\":\\\"file\\\"}}},\\\"lastUsedAtUnixMs\\\":1748471218054},{\\\"displayName\\\":\\\"@EECopilot\\\",\\\"selection\\\":{\\\"type\\\":1,\\\"selectionWithoutUuid\\\":{\\\"text\\\":\\\"```python\\\\nclass EECopilot(Workflow):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"EE Copilot with clean architecture\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\n    name = \\\\\\\"EE Copilot\\\\\\\"\\\\n    description = \\\\\\\"Agentic electrical engineering assistant\\\\\\\"\\\\n    workflow_name = WorkflowName.EE_COPILOT\\\\n\\\\n    def __init__(self, session_id: str = None, *args, **kwargs):\\\\n        super().__init__(\\\\n            name=self.name,\\\\n            description=self.description,\\\\n            session_id=session_id,\\\\n            workflow_name=self.workflow_name,\\\\n            *args,\\\\n            **kwargs,\\\\n        )\\\\n\\\\n        self.model_service = AgentModelService.from_env(\\\\\\\"ATLAS_DYNAMIC_MODEL_SERVICE\\\\\\\")\\\\n        self.llm = self.model_service.load_model()\\\\n        self._app = None\\\\n        self._config = None\\\\n        self._store = None\\\\n        self._store_context = None\\\\n\\\\n        # Initialize clean architecture components\\\\n        # self.response_factory = ResponseFactory()\\\\n        self.context_optimizer = ContextOptimizer()\\\\n        self.response_factory = EnhancedResponseFactory(self.context_optimizer)\\\\n        self.tool_builder = ToolBuilder(self.response_factory)\\\\n        self.synthesizer = MessageSynthesizer(self.llm)\\\\n\\\\n    def _create_synthesis_tool(self) -> Runnable:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Create the synthesis and formatting tool\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        synthesizer = self.synthesizer\\\\n\\\\n        @tool(\\\\n            description=\\\\\\\"ONLY use at the very end after everything has completed! Do not use for single responses or between each agent call!\\\\\\\"\\\\n        )\\\\n        async def synthesize_and_format(\\\\n            primary_message: str = \\\\\\\"\\\\\\\", collected_responses: List[Response] = None, context: str = None\\\\n        ) -> Dict[str, Any]:\\\\n            \\\\\\\"\\\\\\\"\\\\\\\"\\\\n            Synthesize multiple responses and format for API output.\\\\n            This should be called as the FINAL step.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\"\\\\n            if not collected_responses:\\\\n                collected_responses = []\\\\n\\\\n            # Synthesize\\\\n            final_response = await synthesizer.synthesize(\\\\n                primary_message=primary_message, responses=collected_responses, context=context\\\\n            )\\\\n\\\\n            # Convert to API format\\\\n            return final_response.to_api_format()\\\\n\\\\n        synthesize_and_format.name = \\\\\\\"synthesize_and_format\\\\\\\"\\\\n        return synthesize_and_format\\\\n\\\\n    async def _ensure_store(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Ensure store is initialized\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if self._store is None:\\\\n            self._store_context = get_postgres_store(self.postgres_dsn, self.session_id)\\\\n            self._store = await self._store_context.__aenter__()\\\\n        return self._store\\\\n\\\\n    async def cleanup(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Clean up resources - call this when done\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if self._store_context and self._store:\\\\n            await self._store_context.__aexit__(None, None, None)\\\\n            self._store = None\\\\n            self._store_context = None\\\\n\\\\n    async def build(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Build the swarm-based workflow\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        LOG.info(\\\\\\\"Building EE Copilot with clean architecture\\\\\\\")\\\\n\\\\n        store = await self._ensure_store()\\\\n        # async with get_postgres_store(self.postgres_dsn, self.session_id) as store:\\\\n\\\\n        # Create tools using the builder\\\\n        datasheet_tool = self.tool_builder.create_workflow_tool(\\\\n            workflow_class=DatasheetWorkflow,\\\\n            session_id=self.session_id,\\\\n            name=\\\\\\\"datasheet_lookup\\\\\\\",\\\\n            description=DatasheetWorkflow.description,\\\\n            command=\\\\\\\"datasheet-lookup\\\\\\\",\\\\n        )\\\\n\\\\n        base_loader = self.tool_builder.create_workflow_tool(\\\\n            workflow_class=LoaderWorkflow,\\\\n            session_id=self.session_id,\\\\n            name=\\\\\\\"schematic_loader\\\\\\\",\\\\n            description=LoaderWorkflow.description,\\\\n            command=\\\\\\\"loader\\\\\\\",\\\\n        )\\\\n        loader_tool = self.context_optimizer.create_optimized_tool(\\\\n            base_loader,\\\\n            optimization_rules={\\\\n                \\\\\\\"strip_annotations\\\\\\\": True,\\\\n                \\\\\\\"summarize_arrays\\\\\\\": True,\\\\n            },\\\\n        )\\\\n\\\\n        general_ee_tool = self.tool_builder.create_llm_tool(\\\\n            llm=self.llm,\\\\n            name=\\\\\\\"general_ee_qa\\\\\\\",\\\\n            description=\\\\\\\"Answer general EE questions\\\\\\\",\\\\n            system_prompt=\\\\\\\"\\\\\\\"\\\\\\\"You are an expert electrical engineer.\\\\n            Answer questions about circuits, components, and EE concepts.\\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # synthesis_tool = self._create_synthesis_tool()\\\\n\\\\n        # Create agents with clean prompts\\\\n        ee_conversation_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                general_ee_tool,\\\\n                # synthesis_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"ee_conversation\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"ee_conversation\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n                create_handoff_tool(agent_name=\\\\\\\"board_specialist_agent\\\\\\\"),\\\\n                # create_handoff_tool(agent_name=\\\\\\\"loader_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"ee_conversation_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=f\\\\\\\"\\\\\\\"\\\\\\\"\\\\n            You are Atlas, an expert electrical engineering conversational assistant \\\\n            with a persistent memory.\\\\n\\\\n            {get_shared_voice_guidelines()}\\\\n\\\\n            You are ALWAYS the entry point and exit point for conversations.\\\\n\\\\n            CRITICAL RULE: You MUST use a tool for EVERY response, including simple greetings:\\\\n            - For ANY general conversation, greetings, or EE questions → use general_ee_qa\\\\n            - NEVER respond directly without using a tool. Even for \\\\\\\"hello\\\\\\\" or \\\\\\\"thank you\\\\\\\", use general_ee_qa.\\\\n            - For component datasheets → hand off to datasheet_agent  \\\\n            - For schematics/boards → hand off to loader_agent\\\\n            - Use appropriate specialists for technical tasks\\\\n\\\\n            Your capabilities:\\\\n            - Answer ALL general questions and conversations using general_ee_qa tool\\\\n            - Hand off to datasheet_agent for component-specific datasheet questions\\\\n            - For ANYTHING related to boards, schematics, loading, or board analysis → hand off to board_specialist_agent\\\\n            - Maintain conversation memory to provide contextual responses\\\\n\\\\n            MEMORY MANAGEMENT:\\\\n            1. Before responding to ANY query, search your memory for:\\\\n            - User preferences\\\\n            - Previous similar questions\\\\n            - Context from earlier conversations\\\\n            \\\\n            2. After important interactions, store:\\\\n            - User's project context\\\\n            - Frequently asked topics\\\\n            - Key findings or decisions\\\\n            \\\\n            Example flow:\\\\n            - User: \\\\\\\"What boards do we have?\\\\\\\"\\\\n            - You: [Search memory: \\\\\\\"loaded boards\\\\\\\" or \\\\\\\"available boards\\\\\\\"]\\\\n            - If found: Use that info\\\\n            - If not: Use general_ee_qa, then store the answer\\\\n\\\\n            Examples:\\\\n            - User: \\\\\\\"hello\\\\\\\" → Use general_ee_qa(\\\\\\\"hello\\\\\\\")\\\\n            - User: \\\\\\\"what's a resistor?\\\\\\\" → Use general_ee_qa(\\\\\\\"what's a resistor?\\\\\\\")\\\\n            - User: \\\\\\\"load TIDA-01167\\\\\\\" → Hand off to loader_agent\\\\n            - User: \\\\\\\"datasheet for LM5060\\\\\\\" → Hand off to datasheet_agent\\\\n\\\\n            Response Guidelines:\\\\n            - Be conversational, helpful, and maintain context across interactions\\\\n            - When presenting specialist agent results, format them clearly and add your own insights\\\\n            - Preserve technical accuracy while making responses accessible\\\\n            - Include relevant attachments and citations when available\\\\n\\\\n            Remember: ALWAYS use a tool, never respond directly and most importantly, \\\\n            present everything as if YOU are doing it, not other agents or tools.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n        board_specialist_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                loader_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"board_data\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"board_data\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n                create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"board_specialist_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=\\\\\\\"\\\\\\\"\\\\\\\"\\\\n            You are a board specialist handling all board-related tasks.\\\\n\\\\n            CRITICAL MEMORY RULES:\\\\n    \\\\n            1. ALWAYS START WITH MEMORY SEARCH:\\\\n            Before ANY action, search your memory for relevant information.\\\\n            \\\\n            Examples of what to search for:\\\\n            - Board names mentioned → search: \\\\\\\"[board_name]\\\\\\\"\\\\n            - Component questions → search: \\\\\\\"[component_designator]\\\\\\\" or \\\\\\\"[board_name] components\\\\\\\"\\\\n            - Previous analyses → search: \\\\\\\"[board_name] analysis\\\\\\\"\\\\n            \\\\n            2. MEMORY STORAGE AFTER ACTIONS:\\\\n            After completing any significant task, store the results.\\\\n            \\\\n            What to store:\\\\n            - Board loading: \\\\\\\"Loaded [board_name] on [date]. Contains [X] components. Key ICs: [list]\\\\\\\"\\\\n            - Analysis results: \\\\\\\"[board_name] IC analysis: Found [list of ICs with part numbers]\\\\\\\"\\\\n            - Component details: \\\\\\\"[component]: [part_number], [key_properties]\\\\\\\"\\\\n            \\\\n            3. DECISION FLOW:\\\\n            User asks about board/components →\\\\n            1. Search memory FIRST\\\\n            2. If found in memory → use that information\\\\n            3. If not in memory → load/analyze, then store results\\\\n\\\\n            Your tools:\\\\n            1. schematic_loader - loads boards/schematics\\\\n            2. Memory tools - store and retrieve board data\\\\n\\\\n            WORKFLOW:\\\\n            1. When asked to load a board, use schematic_loader\\\\n            2. After loading, ALWAYS store the board data in memory:\\\\n            - Board name\\\\n            - BOM data (components list)\\\\n            - Any analysis results\\\\n            \\\\n            3. For analysis requests (find ICs, count resistors, etc.):\\\\n            - Search your memory for loaded board data\\\\n            - Analyze the BOM data to answer the question\\\\n            - Store analysis results for future reference\\\\n\\\\n            4. For compound queries like \\\\\\\"load X and find all ICs\\\\\\\":\\\\n            - Execute sequentially: load first, then analyze\\\\n            - If component properties are needed (like pin configurations), hand off to datasheet_agent\\\\n\\\\n            IMPORTANT: Only load boards when given SPECIFIC names like:\\\\n            - \\\\\\\"Load TIDA-01167\\\\\\\" → use schematic_loader(\\\\\\\"Load TIDA-01167\\\\\\\")\\\\n            - \\\\\\\"Load @MyBoard\\\\\\\" → use schematic_loader(\\\\\\\"Load @MyBoard\\\\\\\")\\\\n\\\\n            NEVER load a board for vague requests like:\\\\n            - \\\\\\\"Help me load a schematic\\\\\\\" → Return to conversation agent\\\\n            - \\\\\\\"Load a board\\\\\\\" → Return to conversation agent\\\\n\\\\n            IMPORTANT: Memory persists across conversations, while message history gets trimmed.\\\\n            Always prefer memory over relying on conversation history. Use your memory to \\\\n            maintain context about loaded boards and previous analyses.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # Specialist agents remain similar but cleaner\\\\n        datasheet_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                datasheet_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"datasheet_context\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"datasheet_context\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"datasheet_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=\\\\\\\"\\\\\\\"\\\\\\\"You are a datasheet specialist.\\\\n            Use datasheet_lookup to get component information.\\\\n            Store results in memory to avoid repeated lookups.\\\\n        \\\\n            For multiple components, process each one and compile comprehensive results.\\\\n            Always return complete information to ee_conversation_agent.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # loader_agent = create_react_agent(\\\\n        #     model=self.llm,\\\\n        #     tools=[\\\\n        #         loader_tool,\\\\n        #         create_manage_memory_tool(namespace=(\\\\\\\"loader_context\\\\\\\",)),\\\\n        #         create_search_memory_tool(namespace=(\\\\\\\"loader_context\\\\\\\",)),\\\\n        #         create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n        #         create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n        #     ],\\\\n        #     name=\\\\\\\"loader_agent\\\\\\\",\\\\n        #     store=store,\\\\n        #     prompt=f\\\\\\\"\\\\\\\"\\\\\\\"You are a schematic loading specialist.\\\\n        #     Use schematic_loader to load schematics, boards, etc.\\\\n        #     The tool returns Response objects - pass these back to ee_conversation_agent.\\\\n\\\\n        #     {LoaderWorkflow.description}\\\\n        #     \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        # )\\\\n\\\\n        swarm = create_swarm(\\\\n            agents=[ee_conversation_agent, datasheet_agent, board_specialist_agent],\\\\n            default_active_agent=\\\\\\\"ee_conversation_agent\\\\\\\",\\\\n        )\\\\n\\\\n        checkpoint = InMemorySaver()\\\\n        return swarm.compile(checkpointer=checkpoint, store=store)\\\\n\\\\n    async def arun(self, ctx: WorkflowContext, *args, **kwargs) -> AsyncGenerator[Dict[str, Any], None]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Run the workflow, collect all tool‑responses as Response objects,\\\\n        then at the end synthesize one final message (with attachments).\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\n        if self._app is None:\\\\n            self._app = await self.build()\\\\n            self._config = {\\\\\\\"configurable\\\\\\\": {\\\\\\\"thread_id\\\\\\\": self.session_id}}\\\\n\\\\n        input_message = {\\\\\\\"messages\\\\\\\": [{\\\\\\\"role\\\\\\\": \\\\\\\"user\\\\\\\", \\\\\\\"content\\\\\\\": ctx.body}]}\\\\n\\\\n        # 1) Accumulate each tool’s Response\\\\n        responses: List[Response] = []\\\\n        primary_message: str = \\\\\\\"\\\\\\\"\\\\n\\\\n        async for event in self._app.astream(input_message, self._config):\\\\n            for agent_name, agent_data in event.items():\\\\n                LOG.info(f\\\\\\\"Processing event from agent: {agent_name}\\\\\\\")\\\\n                for message in agent_data.get(\\\\\\\"messages\\\\\\\", []):\\\\n                    # TOOL ➔ JSON string ➔ parse ➔ Response\\\\n                    if isinstance(message, ToolMessage):\\\\n                        try:\\\\n                            payload = json.loads(message.content)\\\\n                            if \\\\\\\"_context_optimized\\\\\\\" in payload:\\\\n                                LOG.info(f\\\\\\\"Found optimized response from tool: {message.name}\\\\\\\")\\\\n                            resp_obj = self.response_factory.create_response(payload)\\\\n                            responses.append(resp_obj)\\\\n                        except json.JSONDecodeError:\\\\n                            LOG.warning(\\\\\\\"Couldn’t parse tool JSON\\\\\\\", exc_info=True)\\\\n\\\\n                    # LLM ➔ final text\\\\n                    elif isinstance(message, AIMessage):\\\\n                        primary_message = message.content\\\\n        restored_responses = []\\\\n        for resp in responses:\\\\n            if isinstance(resp, OptimizedWorkflowResponse) and resp.optimization_metadata and resp._context_optimizer:\\\\n                # Create a restored response\\\\n                full_data = resp._context_optimizer.restore_full_response(\\\\n                    {**resp.raw_data, \\\\\\\"_context_optimized\\\\\\\": resp.optimization_metadata}\\\\n                )\\\\n                restored_resp = WorkflowResponse.from_workflow_output(full_data)\\\\n                restored_responses.append(restored_resp)\\\\n                LOG.info(\\\\\\\"Pre-restored an OptimizedWorkflowResponse before synthesis\\\\\\\")\\\\n            else:\\\\n                restored_responses.append(resp)\\\\n\\\\n        # 2) Synthesize once, merging in all attachments\\\\n        final_response: Response = await self.synthesizer.synthesize(\\\\n            primary_message=primary_message,\\\\n            responses=restored_responses,\\\\n            context=None,\\\\n        )\\\\n\\\\n        # 3) Yield the exact API payload\\\\n        yield final_response.to_api_format()\\\\n\\\\n    async def arun_v0(self, ctx: WorkflowContext, *args, **kwargs) -> AsyncGenerator[Dict[str, Any], None]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Run the workflow\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        LOG.info(f\\\\\\\"Processing query: {ctx.body}\\\\\\\")\\\\n\\\\n        if self._app is None:\\\\n            self._app = await self.build()\\\\n            self._config = {\\\\\\\"configurable\\\\\\\": {\\\\\\\"thread_id\\\\\\\": self.session_id}}\\\\n\\\\n        input_message = {\\\\\\\"messages\\\\\\\": [{\\\\\\\"role\\\\\\\": \\\\\\\"user\\\\\\\", \\\\\\\"content\\\\\\\": ctx.body}]}\\\\n\\\\n        # Extract formatted responses from the conversation\\\\n        # async for event in self._app.astream(input_message, self._config):\\\\n        #     for agent_name, agent_data in event.items():\\\\n        #         breakpoint()\\\\n        #         if agent_name == \\\\\\\"ee_conversation_agent\\\\\\\" and \\\\\\\"messages\\\\\\\" in agent_data:\\\\n        #             for message in agent_data[\\\\\\\"messages\\\\\\\"]:\\\\n        #                 if self._is_formatted_response(message):\\\\n        #                     yield self._extract_formatted_content(message)\\\\n        events = []\\\\n        async for event in self._app.astream(input_message, self._config):\\\\n            for agent_name, agent_data in event.items():\\\\n                if \\\\\\\"messages\\\\\\\" in agent_data:\\\\n                    for message in agent_data[\\\\\\\"messages\\\\\\\"]:\\\\n                        if isinstance(message.content, dict) and \\\\\\\"message_content\\\\\\\" in message.content:\\\\n                            yield message.content\\\\n                        # events.append(message)\\\\n                        # if hasattr(message, \\\\\\\"content\\\\\\\") and isinstance(message.content, str):\\\\n                        #     try:\\\\n                        #         import json\\\\n\\\\n                        #         response_dict = json.loads(message.content)\\\\n                        #         if \\\\\\\"message_content\\\\\\\" in response_dict:\\\\n                        #             yield response_dict\\\\n                        #     except:\\\\n                        #         LOG.error(f\\\\\\\"Error parsing message: {message.content}\\\\\\\", exc_info=True)\\\\n                        #         continue\\\\n                        # if (\\\\n                        #     hasattr(message, \\\\\\\"content\\\\\\\")\\\\n                        #     and isinstance(message.content, dict)\\\\n                        #     and \\\\\\\"message_content\\\\\\\" in message.content\\\\n                        # ):\\\\n        # breakpoint()\\\\n        # yield events[-1]\\\\n\\\\n    def _is_formatted_response(self, message: BaseMessage) -> bool:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Check if message contains a formatted response\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        return (\\\\n            hasattr(message, \\\\\\\"type\\\\\\\")\\\\n            and message.type == \\\\\\\"ai\\\\\\\"\\\\n            and hasattr(message, \\\\\\\"content\\\\\\\")\\\\n            and isinstance(message.content, dict)\\\\n            and \\\\\\\"message_content\\\\\\\" in message.content\\\\n        )\\\\n\\\\n    def _extract_formatted_content(self, message: BaseMessage) -> Dict[str, Any]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Extract formatted content from message\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if isinstance(message.content, dict):\\\\n            return message.content\\\\n        # This shouldn't happen with our clean architecture\\\\n        LOG.warning(\\\\\\\"Unexpected message format\\\\\\\")\\\\n        return {\\\\\\\"message_content\\\\\\\": [{\\\\\\\"content\\\\\\\": str(message.content)}]}\\\\n\\\\n\\\\n\\\\n```\\\",\\\"rawText\\\":\\\"class EECopilot(Workflow):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"EE Copilot with clean architecture\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\n    name = \\\\\\\"EE Copilot\\\\\\\"\\\\n    description = \\\\\\\"Agentic electrical engineering assistant\\\\\\\"\\\\n    workflow_name = WorkflowName.EE_COPILOT\\\\n\\\\n    def __init__(self, session_id: str = None, *args, **kwargs):\\\\n        super().__init__(\\\\n            name=self.name,\\\\n            description=self.description,\\\\n            session_id=session_id,\\\\n            workflow_name=self.workflow_name,\\\\n            *args,\\\\n            **kwargs,\\\\n        )\\\\n\\\\n        self.model_service = AgentModelService.from_env(\\\\\\\"ATLAS_DYNAMIC_MODEL_SERVICE\\\\\\\")\\\\n        self.llm = self.model_service.load_model()\\\\n        self._app = None\\\\n        self._config = None\\\\n        self._store = None\\\\n        self._store_context = None\\\\n\\\\n        # Initialize clean architecture components\\\\n        # self.response_factory = ResponseFactory()\\\\n        self.context_optimizer = ContextOptimizer()\\\\n        self.response_factory = EnhancedResponseFactory(self.context_optimizer)\\\\n        self.tool_builder = ToolBuilder(self.response_factory)\\\\n        self.synthesizer = MessageSynthesizer(self.llm)\\\\n\\\\n    def _create_synthesis_tool(self) -> Runnable:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Create the synthesis and formatting tool\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        synthesizer = self.synthesizer\\\\n\\\\n        @tool(\\\\n            description=\\\\\\\"ONLY use at the very end after everything has completed! Do not use for single responses or between each agent call!\\\\\\\"\\\\n        )\\\\n        async def synthesize_and_format(\\\\n            primary_message: str = \\\\\\\"\\\\\\\", collected_responses: List[Response] = None, context: str = None\\\\n        ) -> Dict[str, Any]:\\\\n            \\\\\\\"\\\\\\\"\\\\\\\"\\\\n            Synthesize multiple responses and format for API output.\\\\n            This should be called as the FINAL step.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\"\\\\n            if not collected_responses:\\\\n                collected_responses = []\\\\n\\\\n            # Synthesize\\\\n            final_response = await synthesizer.synthesize(\\\\n                primary_message=primary_message, responses=collected_responses, context=context\\\\n            )\\\\n\\\\n            # Convert to API format\\\\n            return final_response.to_api_format()\\\\n\\\\n        synthesize_and_format.name = \\\\\\\"synthesize_and_format\\\\\\\"\\\\n        return synthesize_and_format\\\\n\\\\n    async def _ensure_store(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Ensure store is initialized\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if self._store is None:\\\\n            self._store_context = get_postgres_store(self.postgres_dsn, self.session_id)\\\\n            self._store = await self._store_context.__aenter__()\\\\n        return self._store\\\\n\\\\n    async def cleanup(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Clean up resources - call this when done\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if self._store_context and self._store:\\\\n            await self._store_context.__aexit__(None, None, None)\\\\n            self._store = None\\\\n            self._store_context = None\\\\n\\\\n    async def build(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Build the swarm-based workflow\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        LOG.info(\\\\\\\"Building EE Copilot with clean architecture\\\\\\\")\\\\n\\\\n        store = await self._ensure_store()\\\\n        # async with get_postgres_store(self.postgres_dsn, self.session_id) as store:\\\\n\\\\n        # Create tools using the builder\\\\n        datasheet_tool = self.tool_builder.create_workflow_tool(\\\\n            workflow_class=DatasheetWorkflow,\\\\n            session_id=self.session_id,\\\\n            name=\\\\\\\"datasheet_lookup\\\\\\\",\\\\n            description=DatasheetWorkflow.description,\\\\n            command=\\\\\\\"datasheet-lookup\\\\\\\",\\\\n        )\\\\n\\\\n        base_loader = self.tool_builder.create_workflow_tool(\\\\n            workflow_class=LoaderWorkflow,\\\\n            session_id=self.session_id,\\\\n            name=\\\\\\\"schematic_loader\\\\\\\",\\\\n            description=LoaderWorkflow.description,\\\\n            command=\\\\\\\"loader\\\\\\\",\\\\n        )\\\\n        loader_tool = self.context_optimizer.create_optimized_tool(\\\\n            base_loader,\\\\n            optimization_rules={\\\\n                \\\\\\\"strip_annotations\\\\\\\": True,\\\\n                \\\\\\\"summarize_arrays\\\\\\\": True,\\\\n            },\\\\n        )\\\\n\\\\n        general_ee_tool = self.tool_builder.create_llm_tool(\\\\n            llm=self.llm,\\\\n            name=\\\\\\\"general_ee_qa\\\\\\\",\\\\n            description=\\\\\\\"Answer general EE questions\\\\\\\",\\\\n            system_prompt=\\\\\\\"\\\\\\\"\\\\\\\"You are an expert electrical engineer.\\\\n            Answer questions about circuits, components, and EE concepts.\\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # synthesis_tool = self._create_synthesis_tool()\\\\n\\\\n        # Create agents with clean prompts\\\\n        ee_conversation_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                general_ee_tool,\\\\n                # synthesis_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"ee_conversation\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"ee_conversation\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n                create_handoff_tool(agent_name=\\\\\\\"board_specialist_agent\\\\\\\"),\\\\n                # create_handoff_tool(agent_name=\\\\\\\"loader_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"ee_conversation_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=f\\\\\\\"\\\\\\\"\\\\\\\"\\\\n            You are Atlas, an expert electrical engineering conversational assistant \\\\n            with a persistent memory.\\\\n\\\\n            {get_shared_voice_guidelines()}\\\\n\\\\n            You are ALWAYS the entry point and exit point for conversations.\\\\n\\\\n            CRITICAL RULE: You MUST use a tool for EVERY response, including simple greetings:\\\\n            - For ANY general conversation, greetings, or EE questions → use general_ee_qa\\\\n            - NEVER respond directly without using a tool. Even for \\\\\\\"hello\\\\\\\" or \\\\\\\"thank you\\\\\\\", use general_ee_qa.\\\\n            - For component datasheets → hand off to datasheet_agent  \\\\n            - For schematics/boards → hand off to loader_agent\\\\n            - Use appropriate specialists for technical tasks\\\\n\\\\n            Your capabilities:\\\\n            - Answer ALL general questions and conversations using general_ee_qa tool\\\\n            - Hand off to datasheet_agent for component-specific datasheet questions\\\\n            - For ANYTHING related to boards, schematics, loading, or board analysis → hand off to board_specialist_agent\\\\n            - Maintain conversation memory to provide contextual responses\\\\n\\\\n            MEMORY MANAGEMENT:\\\\n            1. Before responding to ANY query, search your memory for:\\\\n            - User preferences\\\\n            - Previous similar questions\\\\n            - Context from earlier conversations\\\\n            \\\\n            2. After important interactions, store:\\\\n            - User's project context\\\\n            - Frequently asked topics\\\\n            - Key findings or decisions\\\\n            \\\\n            Example flow:\\\\n            - User: \\\\\\\"What boards do we have?\\\\\\\"\\\\n            - You: [Search memory: \\\\\\\"loaded boards\\\\\\\" or \\\\\\\"available boards\\\\\\\"]\\\\n            - If found: Use that info\\\\n            - If not: Use general_ee_qa, then store the answer\\\\n\\\\n            Examples:\\\\n            - User: \\\\\\\"hello\\\\\\\" → Use general_ee_qa(\\\\\\\"hello\\\\\\\")\\\\n            - User: \\\\\\\"what's a resistor?\\\\\\\" → Use general_ee_qa(\\\\\\\"what's a resistor?\\\\\\\")\\\\n            - User: \\\\\\\"load TIDA-01167\\\\\\\" → Hand off to loader_agent\\\\n            - User: \\\\\\\"datasheet for LM5060\\\\\\\" → Hand off to datasheet_agent\\\\n\\\\n            Response Guidelines:\\\\n            - Be conversational, helpful, and maintain context across interactions\\\\n            - When presenting specialist agent results, format them clearly and add your own insights\\\\n            - Preserve technical accuracy while making responses accessible\\\\n            - Include relevant attachments and citations when available\\\\n\\\\n            Remember: ALWAYS use a tool, never respond directly and most importantly, \\\\n            present everything as if YOU are doing it, not other agents or tools.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n        board_specialist_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                loader_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"board_data\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"board_data\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n                create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"board_specialist_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=\\\\\\\"\\\\\\\"\\\\\\\"\\\\n            You are a board specialist handling all board-related tasks.\\\\n\\\\n            CRITICAL MEMORY RULES:\\\\n    \\\\n            1. ALWAYS START WITH MEMORY SEARCH:\\\\n            Before ANY action, search your memory for relevant information.\\\\n            \\\\n            Examples of what to search for:\\\\n            - Board names mentioned → search: \\\\\\\"[board_name]\\\\\\\"\\\\n            - Component questions → search: \\\\\\\"[component_designator]\\\\\\\" or \\\\\\\"[board_name] components\\\\\\\"\\\\n            - Previous analyses → search: \\\\\\\"[board_name] analysis\\\\\\\"\\\\n            \\\\n            2. MEMORY STORAGE AFTER ACTIONS:\\\\n            After completing any significant task, store the results.\\\\n            \\\\n            What to store:\\\\n            - Board loading: \\\\\\\"Loaded [board_name] on [date]. Contains [X] components. Key ICs: [list]\\\\\\\"\\\\n            - Analysis results: \\\\\\\"[board_name] IC analysis: Found [list of ICs with part numbers]\\\\\\\"\\\\n            - Component details: \\\\\\\"[component]: [part_number], [key_properties]\\\\\\\"\\\\n            \\\\n            3. DECISION FLOW:\\\\n            User asks about board/components →\\\\n            1. Search memory FIRST\\\\n            2. If found in memory → use that information\\\\n            3. If not in memory → load/analyze, then store results\\\\n\\\\n            Your tools:\\\\n            1. schematic_loader - loads boards/schematics\\\\n            2. Memory tools - store and retrieve board data\\\\n\\\\n            WORKFLOW:\\\\n            1. When asked to load a board, use schematic_loader\\\\n            2. After loading, ALWAYS store the board data in memory:\\\\n            - Board name\\\\n            - BOM data (components list)\\\\n            - Any analysis results\\\\n            \\\\n            3. For analysis requests (find ICs, count resistors, etc.):\\\\n            - Search your memory for loaded board data\\\\n            - Analyze the BOM data to answer the question\\\\n            - Store analysis results for future reference\\\\n\\\\n            4. For compound queries like \\\\\\\"load X and find all ICs\\\\\\\":\\\\n            - Execute sequentially: load first, then analyze\\\\n            - If component properties are needed (like pin configurations), hand off to datasheet_agent\\\\n\\\\n            IMPORTANT: Only load boards when given SPECIFIC names like:\\\\n            - \\\\\\\"Load TIDA-01167\\\\\\\" → use schematic_loader(\\\\\\\"Load TIDA-01167\\\\\\\")\\\\n            - \\\\\\\"Load @MyBoard\\\\\\\" → use schematic_loader(\\\\\\\"Load @MyBoard\\\\\\\")\\\\n\\\\n            NEVER load a board for vague requests like:\\\\n            - \\\\\\\"Help me load a schematic\\\\\\\" → Return to conversation agent\\\\n            - \\\\\\\"Load a board\\\\\\\" → Return to conversation agent\\\\n\\\\n            IMPORTANT: Memory persists across conversations, while message history gets trimmed.\\\\n            Always prefer memory over relying on conversation history. Use your memory to \\\\n            maintain context about loaded boards and previous analyses.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # Specialist agents remain similar but cleaner\\\\n        datasheet_agent = create_react_agent(\\\\n            model=self.llm,\\\\n            tools=[\\\\n                datasheet_tool,\\\\n                create_manage_memory_tool(namespace=(\\\\\\\"datasheet_context\\\\\\\",)),\\\\n                create_search_memory_tool(namespace=(\\\\\\\"datasheet_context\\\\\\\",)),\\\\n                create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n            ],\\\\n            name=\\\\\\\"datasheet_agent\\\\\\\",\\\\n            store=store,\\\\n            prompt=\\\\\\\"\\\\\\\"\\\\\\\"You are a datasheet specialist.\\\\n            Use datasheet_lookup to get component information.\\\\n            Store results in memory to avoid repeated lookups.\\\\n        \\\\n            For multiple components, process each one and compile comprehensive results.\\\\n            Always return complete information to ee_conversation_agent.\\\\n            \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        )\\\\n\\\\n        # loader_agent = create_react_agent(\\\\n        #     model=self.llm,\\\\n        #     tools=[\\\\n        #         loader_tool,\\\\n        #         create_manage_memory_tool(namespace=(\\\\\\\"loader_context\\\\\\\",)),\\\\n        #         create_search_memory_tool(namespace=(\\\\\\\"loader_context\\\\\\\",)),\\\\n        #         create_handoff_tool(agent_name=\\\\\\\"ee_conversation_agent\\\\\\\"),\\\\n        #         create_handoff_tool(agent_name=\\\\\\\"datasheet_agent\\\\\\\"),\\\\n        #     ],\\\\n        #     name=\\\\\\\"loader_agent\\\\\\\",\\\\n        #     store=store,\\\\n        #     prompt=f\\\\\\\"\\\\\\\"\\\\\\\"You are a schematic loading specialist.\\\\n        #     Use schematic_loader to load schematics, boards, etc.\\\\n        #     The tool returns Response objects - pass these back to ee_conversation_agent.\\\\n\\\\n        #     {LoaderWorkflow.description}\\\\n        #     \\\\\\\"\\\\\\\"\\\\\\\",\\\\n        # )\\\\n\\\\n        swarm = create_swarm(\\\\n            agents=[ee_conversation_agent, datasheet_agent, board_specialist_agent],\\\\n            default_active_agent=\\\\\\\"ee_conversation_agent\\\\\\\",\\\\n        )\\\\n\\\\n        checkpoint = InMemorySaver()\\\\n        return swarm.compile(checkpointer=checkpoint, store=store)\\\\n\\\\n    async def arun(self, ctx: WorkflowContext, *args, **kwargs) -> AsyncGenerator[Dict[str, Any], None]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Run the workflow, collect all tool‑responses as Response objects,\\\\n        then at the end synthesize one final message (with attachments).\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\n        if self._app is None:\\\\n            self._app = await self.build()\\\\n            self._config = {\\\\\\\"configurable\\\\\\\": {\\\\\\\"thread_id\\\\\\\": self.session_id}}\\\\n\\\\n        input_message = {\\\\\\\"messages\\\\\\\": [{\\\\\\\"role\\\\\\\": \\\\\\\"user\\\\\\\", \\\\\\\"content\\\\\\\": ctx.body}]}\\\\n\\\\n        # 1) Accumulate each tool’s Response\\\\n        responses: List[Response] = []\\\\n        primary_message: str = \\\\\\\"\\\\\\\"\\\\n\\\\n        async for event in self._app.astream(input_message, self._config):\\\\n            for agent_name, agent_data in event.items():\\\\n                LOG.info(f\\\\\\\"Processing event from agent: {agent_name}\\\\\\\")\\\\n                for message in agent_data.get(\\\\\\\"messages\\\\\\\", []):\\\\n                    # TOOL ➔ JSON string ➔ parse ➔ Response\\\\n                    if isinstance(message, ToolMessage):\\\\n                        try:\\\\n                            payload = json.loads(message.content)\\\\n                            if \\\\\\\"_context_optimized\\\\\\\" in payload:\\\\n                                LOG.info(f\\\\\\\"Found optimized response from tool: {message.name}\\\\\\\")\\\\n                            resp_obj = self.response_factory.create_response(payload)\\\\n                            responses.append(resp_obj)\\\\n                        except json.JSONDecodeError:\\\\n                            LOG.warning(\\\\\\\"Couldn’t parse tool JSON\\\\\\\", exc_info=True)\\\\n\\\\n                    # LLM ➔ final text\\\\n                    elif isinstance(message, AIMessage):\\\\n                        primary_message = message.content\\\\n        restored_responses = []\\\\n        for resp in responses:\\\\n            if isinstance(resp, OptimizedWorkflowResponse) and resp.optimization_metadata and resp._context_optimizer:\\\\n                # Create a restored response\\\\n                full_data = resp._context_optimizer.restore_full_response(\\\\n                    {**resp.raw_data, \\\\\\\"_context_optimized\\\\\\\": resp.optimization_metadata}\\\\n                )\\\\n                restored_resp = WorkflowResponse.from_workflow_output(full_data)\\\\n                restored_responses.append(restored_resp)\\\\n                LOG.info(\\\\\\\"Pre-restored an OptimizedWorkflowResponse before synthesis\\\\\\\")\\\\n            else:\\\\n                restored_responses.append(resp)\\\\n\\\\n        # 2) Synthesize once, merging in all attachments\\\\n        final_response: Response = await self.synthesizer.synthesize(\\\\n            primary_message=primary_message,\\\\n            responses=restored_responses,\\\\n            context=None,\\\\n        )\\\\n\\\\n        # 3) Yield the exact API payload\\\\n        yield final_response.to_api_format()\\\\n\\\\n    async def arun_v0(self, ctx: WorkflowContext, *args, **kwargs) -> AsyncGenerator[Dict[str, Any], None]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Run the workflow\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        LOG.info(f\\\\\\\"Processing query: {ctx.body}\\\\\\\")\\\\n\\\\n        if self._app is None:\\\\n            self._app = await self.build()\\\\n            self._config = {\\\\\\\"configurable\\\\\\\": {\\\\\\\"thread_id\\\\\\\": self.session_id}}\\\\n\\\\n        input_message = {\\\\\\\"messages\\\\\\\": [{\\\\\\\"role\\\\\\\": \\\\\\\"user\\\\\\\", \\\\\\\"content\\\\\\\": ctx.body}]}\\\\n\\\\n        # Extract formatted responses from the conversation\\\\n        # async for event in self._app.astream(input_message, self._config):\\\\n        #     for agent_name, agent_data in event.items():\\\\n        #         breakpoint()\\\\n        #         if agent_name == \\\\\\\"ee_conversation_agent\\\\\\\" and \\\\\\\"messages\\\\\\\" in agent_data:\\\\n        #             for message in agent_data[\\\\\\\"messages\\\\\\\"]:\\\\n        #                 if self._is_formatted_response(message):\\\\n        #                     yield self._extract_formatted_content(message)\\\\n        events = []\\\\n        async for event in self._app.astream(input_message, self._config):\\\\n            for agent_name, agent_data in event.items():\\\\n                if \\\\\\\"messages\\\\\\\" in agent_data:\\\\n                    for message in agent_data[\\\\\\\"messages\\\\\\\"]:\\\\n                        if isinstance(message.content, dict) and \\\\\\\"message_content\\\\\\\" in message.content:\\\\n                            yield message.content\\\\n                        # events.append(message)\\\\n                        # if hasattr(message, \\\\\\\"content\\\\\\\") and isinstance(message.content, str):\\\\n                        #     try:\\\\n                        #         import json\\\\n\\\\n                        #         response_dict = json.loads(message.content)\\\\n                        #         if \\\\\\\"message_content\\\\\\\" in response_dict:\\\\n                        #             yield response_dict\\\\n                        #     except:\\\\n                        #         LOG.error(f\\\\\\\"Error parsing message: {message.content}\\\\\\\", exc_info=True)\\\\n                        #         continue\\\\n                        # if (\\\\n                        #     hasattr(message, \\\\\\\"content\\\\\\\")\\\\n                        #     and isinstance(message.content, dict)\\\\n                        #     and \\\\\\\"message_content\\\\\\\" in message.content\\\\n                        # ):\\\\n        # breakpoint()\\\\n        # yield events[-1]\\\\n\\\\n    def _is_formatted_response(self, message: BaseMessage) -> bool:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Check if message contains a formatted response\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        return (\\\\n            hasattr(message, \\\\\\\"type\\\\\\\")\\\\n            and message.type == \\\\\\\"ai\\\\\\\"\\\\n            and hasattr(message, \\\\\\\"content\\\\\\\")\\\\n            and isinstance(message.content, dict)\\\\n            and \\\\\\\"message_content\\\\\\\" in message.content\\\\n        )\\\\n\\\\n    def _extract_formatted_content(self, message: BaseMessage) -> Dict[str, Any]:\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"Extract formatted content from message\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        if isinstance(message.content, dict):\\\\n            return message.content\\\\n        # This shouldn't happen with our clean architecture\\\\n        LOG.warning(\\\\\\\"Unexpected message format\\\\\\\")\\\\n        return {\\\\\\\"message_content\\\\\\\": [{\\\\\\\"content\\\\\\\": str(message.content)}]}\\\\n\\\\n\\\\n\\\",\\\"range\\\":{\\\"selectionStartLineNumber\\\":561,\\\"selectionStartColumn\\\":1,\\\"positionLineNumber\\\":980,\\\"positionColumn\\\":1},\\\"uri\\\":{\\\"$mid\\\":1,\\\"fsPath\\\":\\\"